# Copy to .env and adjust. Docker Compose reads this file automatically.

# --- Django core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
# Comma-separated hostnames/IPs this instance is served from.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Needed if you access the app via https or a non-default origin.
# DJANGO_CSRF_TRUSTED_ORIGINS=https://muster.example.lan
DJANGO_TIME_ZONE=UTC

# Allow visitors to self-register. Set to False once your players are in.
REGISTRATION_OPEN=True
# Serve uploaded photos through Django (fine for a homelab LAN).
SERVE_MEDIA=True
# Enable only when serving behind HTTPS/TLS.
# DJANGO_SECURE_SSL=False

# --- PostgreSQL (used by both the db and web services) ---
POSTGRES_DB=musterhall
POSTGRES_USER=musterhall
POSTGRES_PASSWORD=change-me-too
# POSTGRES_HOST/PORT are set automatically by docker-compose for the web service.

# --- Host port the app is published on ---
WEB_PORT=8000

# --- Optional bootstrap on first container start ---
# SEED_ON_START=true
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=change-me-admin
